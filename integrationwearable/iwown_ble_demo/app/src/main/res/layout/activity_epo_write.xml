<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="15dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical">

    <TextView
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_width="wrap_content"
        android:id="@+id/epoFileTxt1"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="20dp"
        android:textSize="18dp"
        android:text="offline路径:"

        android:layout_height="wrap_content"/>

    <TextView
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_width="wrap_content"
        android:id="@+id/epoFileTxt2"
        app:layout_constraintTop_toBottomOf="@id/epoFileTxt1"
        android:layout_marginTop="10dp"
        android:textSize="18dp"
        android:text="online路径:"
        android:layout_height="wrap_content"/>

    <Button
        android:layout_width="wrap_content"
        android:textSize="18dp"
        android:id="@+id/epoFileBtn1"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_marginTop="10dp"
        android:minWidth="100dp"
        android:text="选择offline(弃用)"
        android:textAllCaps="false"
        app:layout_constraintTop_toBottomOf="@id/epoFileTxt2"
        android:layout_height="wrap_content"/>

    <Button
        android:layout_width="wrap_content"
        android:textSize="18dp"
        android:id="@+id/epoFileBtn2"
        android:layout_marginTop="10dp"
        android:textAllCaps="false"
        app:layout_constraintLeft_toRightOf="@+id/epoFileBtn1"
        android:layout_marginLeft="20dp"
        android:minWidth="100dp"
        android:text="选择online(弃用)"
        app:layout_constraintTop_toBottomOf="@id/epoFileTxt2"
        android:layout_height="wrap_content"/>

    <Button
        android:layout_width="wrap_content"
        android:textSize="18dp"
        android:id="@+id/epoSendFileBtn"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_marginTop="10dp"
        android:minWidth="150dp"
        android:text="写入EPO"
        app:layout_constraintTop_toBottomOf="@id/epoFileBtn1"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/epoSyncTitleTxt"
        android:layout_width="wrap_content"
        android:textSize="30dp"
        android:text="进度:"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@+id/epoSendFileBtn"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/epoSyncTxt"
        android:layout_width="wrap_content"
        android:textSize="30dp"
        android:text="0%"
        android:layout_marginLeft="5dp"
        android:textColor="@color/blue"
        app:layout_constraintLeft_toRightOf="@+id/epoSyncTitleTxt"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@+id/epoSendFileBtn"
        android:layout_height="wrap_content"/>



</androidx.constraintlayout.widget.ConstraintLayout>