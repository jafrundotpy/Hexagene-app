<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/jxToolbarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        android:theme="@style/AppTheme.AppBarOverlay">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarSetting"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#0475E4"
            app:title="JXUpgrade"
            app:popupTheme="@style/AppTheme.PopupOverlay">
        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        app:layout_constraintTop_toBottomOf="@+id/jxToolbarLayout"
        android:id="@+id/ctp_can_upgrade"
        android:layout_width="match_parent"
        android:layout_marginTop="70dp"
        android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/ctp_upload_img"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:src="@mipmap/upload_img"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <TextView
        android:id="@+id/type_status_txt"
        app:layout_constraintTop_toBottomOf="@+id/ctp_upload_img"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:textSize="14dp"
        android:layout_marginTop="10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <ProgressBar
        android:id="@+id/ctp_progress"
        android:layout_width="match_parent"
        app:layout_constraintTop_toBottomOf="@+id/ctp_upload_img"
        android:layout_marginTop="50dp"
        android:layout_marginLeft="22dp"
        android:layout_marginRight="22dp"
        android:max="100"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:progressDrawable="@drawable/iv_progress_style"
        android:layout_height="17dp"/>
    <TextView
        android:id="@+id/progressTextview"
        android:layout_width="wrap_content"
        android:textSize="24dp"
        android:text="0%"
        app:layout_constraintTop_toBottomOf="@+id/ctp_progress"
        android:layout_marginTop="15dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/selectMyFile"
        android:layout_width="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/progressTextview"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:text="Add File"
        android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/beginUpBtn"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:layout_marginTop="4dp"
            android:minWidth="130dp"
            android:text="Start Upgrade"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/selectMyFile" />
<!--        android:background="@drawable/upfirmware_bg_selector"-->


        <TextView
            android:id="@+id/selectFilePath"
            android:layout_width="wrap_content"
            android:textSize="14dp"
            android:text="升级文件: "
            app:layout_constraintTop_toBottomOf="@+id/beginUpBtn"
            android:layout_marginTop="15dp"
            android:textColor="@color/black"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            android:layout_height="wrap_content"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/filesLayout"
        android:layout_width="match_parent"
        android:layout_marginTop="25dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/ctp_can_upgrade"
        android:layout_height="wrap_content">

    </LinearLayout>


    
</androidx.constraintlayout.widget.ConstraintLayout>