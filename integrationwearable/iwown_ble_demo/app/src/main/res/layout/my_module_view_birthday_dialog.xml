<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="202dp"
    android:background="@drawable/my_module_profile_dialog_bg_shape">

    <com.bigkoo.pickerview.lib.WheelView
        android:id="@+id/wheel_view_year"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintEnd_toStartOf="@id/wheel_view_month"
        app:layout_constraintStart_toStartOf="parent"
        app:pickerview_dividerColor="#00000000"
        app:pickerview_lineSpacingMultiplier="3.4"
        app:pickerview_textColorCenter="#ffffff"
        app:pickerview_textColorOut="#71747C"
        app:pickerview_textSize="22sp" />

    <com.bigkoo.pickerview.lib.WheelView
        android:id="@+id/wheel_view_month"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintEnd_toStartOf="@id/wheel_view_day"
        app:layout_constraintStart_toEndOf="@id/wheel_view_year"
        app:pickerview_dividerColor="#00000000"
        app:pickerview_lineSpacingMultiplier="3.4"
        app:pickerview_textColorCenter="#ffffff"
        app:pickerview_textColorOut="#71747C"
        app:pickerview_textSize="22sp" />

    <com.bigkoo.pickerview.lib.WheelView
        android:id="@+id/wheel_view_day"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/wheel_view_month"
        app:pickerview_dividerColor="#00000000"
        app:pickerview_lineSpacingMultiplier="3.4"
        app:pickerview_textColorCenter="#ffffff"
        app:pickerview_textColorOut="#71747C"
        app:pickerview_textSize="22sp" />

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="23dp"
        android:background="#3C424C"
        app:layout_constraintEnd_toStartOf="@id/wheel_view_month"
        app:layout_constraintStart_toEndOf="@id/wheel_view_year" />

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="23dp"
        android:background="#3C424C"
        app:layout_constraintEnd_toStartOf="@id/wheel_view_day"
        app:layout_constraintStart_toEndOf="@id/wheel_view_month" />

</androidx.constraintlayout.widget.ConstraintLayout>